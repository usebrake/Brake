{
  "name": "brake-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron React shell for the Brake desktop GUI.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "web": "vite --host 127.0.0.1",
    "desktop": "wait-on http://127.0.0.1:5173 && electron .",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "electron": "^42.3.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  }
}
